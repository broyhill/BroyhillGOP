# =============================================================================
# BroyhillGOP — environment template
# =============================================================================
# Copy to .env (which is gitignored) and fill in real values locally.
# Never commit real credentials to this repo. Repo is PUBLIC.
# =============================================================================

# -----------------------------------------------------------------------------
# Hetzner Postgres (the production donor database — sacred)
# -----------------------------------------------------------------------------
# Host: 37.27.169.232 | Port: 5432 | DB: postgres | User: postgres
PG_PASSWORD=<set-via-env-only>
# URL-encoded variant for connection strings (encode @ as %40, $ as %24, etc.)
PG_PASSWORD_URLENCODED=<url-encoded-form-of-PG_PASSWORD>

# Hetzner SSH password (for shell access, not Postgres)
HETZNER_SSH_PASSWORD=<set-via-env-only>

# -----------------------------------------------------------------------------
# Supabase — primary BroyhillGOP project
# -----------------------------------------------------------------------------
# Get keys from: Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=<jwt-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<jwt-service-role-key>     # NEVER expose client-side

# Supabase database password (for direct postgres connections)
SUPABASE_DB_PASSWORD=<set-via-env-only>
SUPABASE_DB_PASSWORD_URLENCODED=<url-encoded-form-of-SUPABASE_DB_PASSWORD>

# Connection strings (preferred over individual fields)
# Direct port 5432 — recommended for ingestion / long queries
SUPABASE_DB_URL=postgresql://postgres.[PROJECT_REF]:${SUPABASE_DB_PASSWORD_URLENCODED}@aws-1-us-east-1.pooler.supabase.com:6543/postgres
# Alternative: DATABASE_URL (used if SUPABASE_DB_URL is not set)
# DATABASE_URL=postgresql://postgres:${SUPABASE_DB_PASSWORD}@db.[PROJECT_REF].supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# Third-party APIs (set as needed; leave blank if not used)
# -----------------------------------------------------------------------------
GEOCODIO_API_KEY=
APOLLO_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_MAPS_API_KEY=
